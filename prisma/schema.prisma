generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Ticker {
  id        String       @id @default(cuid())
  symbol    String       @unique
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  cycles    WheelCycle[]
}

model WheelCycle {
  id           String     @id @default(cuid())
  tickerId     String
  ticker       Ticker     @relation(fields: [tickerId], references: [id])
  stage        String     // SELLING_PUTS | HOLDING_SHARES | SELLING_CALLS
  costBasis    Float?
  sharesHeld   Int        @default(0)
  totalPremium Float      @default(0)
  realizedPL   Float      @default(0)
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
  contracts    Contract[]
}

model Contract {
  id            String     @id @default(cuid())
  cycleId       String
  cycle         WheelCycle @relation(fields: [cycleId], references: [id])
  alpacaOrderId String?
  type          String     // PUT | CALL
  action        String     // SELL_TO_OPEN | BUY_TO_CLOSE
  symbol        String     // OCC symbol
  strikePrice   Float
  expiration    DateTime
  premium       Float
  quantity      Int        @default(1)
  status        String     // PENDING | OPEN | CLOSED | ASSIGNED | EXPIRED
  openedAt      DateTime   @default(now())
  closedAt      DateTime?
  closePrice    Float?
  closedReason  String?    // PROFIT_TARGET | EXPIRATION | ASSIGNMENT | MANUAL
}

model TradeLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  level     String   // INFO | WARN | ERROR | TRADE
  ticker    String?
  message   String
  data      String?  // JSON blob
}
